generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dealership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String   @unique
  ownerEmail     String   @map("owner_email")
  logoUrl        String?  @map("logo_url")
  primaryColor   String   @default("#2563eb") @map("primary_color")
  secondaryColor String   @default("#f97316") @map("secondary_color")
  heroTitle      String   @default("Find Your Perfect Drive") @map("hero_title")
  heroSubtitle   String   @default("Browse our curated selection of premium vehicles.") @map("hero_subtitle")
  phone          String   @default("")
  address        String   @default("")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  cars Car[]

  @@map("dealerships")
}

model Car {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand        String
  model        String
  year         Int      @default(dbgenerated("extract(year from now())::int"))
  price        Decimal  @default(0)
  mileage      Int      @default(0)
  fuel         String   @default("Petrol")
  transmission String   @default("Automatic")
  power        Int      @default(0)
  color        String   @default("")
  condition    String   @default("New")
  description  String   @default("")
  images       String[] @default([])
  features     String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  dealershipId String     @map("dealership_id") @db.Uuid
  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@map("cars")
}
